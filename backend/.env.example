# Базові параметри застосунку та підключень.
APP_NAME=Motion Nova API
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://root:password@localhost:5433/fcms
REDIS_URL=redis://localhost:6379/0

# JWT-секрети та час життя токенів.
JWT_SECRET_KEY=change-me
JWT_REFRESH_SECRET_KEY=change-me-too
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Налаштування cookies і тривалості неактивної адмін-сесії.
ADMIN_IDLE_TIMEOUT_MINUTES=30
SECURE_COOKIES=true
COOKIE_DOMAIN=

# CORS-джерела у CSV-форматі.
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# Поведінка застосунку при старті.
RUN_DB_MIGRATIONS=true
SEED_DEMO_DATA=false
SERVE_FRONTEND=false
FRONTEND_DIST_PATH=

# Ліміти частоти запитів для auth і підписок.
AUTH_LOGIN_RATE_LIMIT=5
AUTH_REGISTER_RATE_LIMIT=3
AUTH_REFRESH_RATE_LIMIT=10
SUBSCRIPTION_PURCHASE_RATE_LIMIT=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Read-only MCP сервер (його споживає зовнішній Dify AI-агент).
MCP_API_TOKEN=local-dev-mcp-token
MCP_PUBLIC_URL=http://localhost:8000/mcp
# For Dify inside Docker network use http://motion-backend:8000/mcp in Dify UI
MCP_TOOL_TIMEOUT_SECONDS=5
